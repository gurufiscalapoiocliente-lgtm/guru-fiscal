# GEMINI_API_KEY: Obrigatório para chamadas à API Gemini.
# Em desenvolvimento: cria um ficheiro .env.local na raiz com este valor.
# Em produção (Vercel): configura em Vercel > Settings > Environment Variables.
GEMINI_API_KEY="a_tua_chave_gemini_aqui"

# APP_URL: URL onde a app está hospedada.
# Em produção é injetado automaticamente pelo Vercel.
APP_URL="https://o-teu-dominio.vercel.app"
